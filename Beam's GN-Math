<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Beam's GN-Math</title>
    <meta name="description" content="Premium unblocked interactive experiences. Fast, fluid, and vibrant.">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Space+Mono:ital@0;1&display=swap" rel="stylesheet">
    
    <base href="https://cdn.jsdelivr.net/gh/gn-math/gn-math.github.io@main/">
    <link rel="icon" type="image/png" href="favicon.png">

    <style>
        /* =========================================
           VIBRANT THEME VARIABLES & RESET
           ========================================= */
        :root {
            --bg-base: #0B0A10;
            --accent-warm: #FF4D6D;
            --accent-bright: #FF9E00;
            --accent-cool: #7B2CBF;
            
            --text-primary: #FFFFFF;
            --text-secondary: rgba(255, 255, 255, 0.7);
            
            --glass-bg: rgba(20, 18, 28, 0.4);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-blur: blur(24px);
            
            --radius-md: 16px;
            --radius-lg: 24px;
            --radius-full: 9999px;
            
            --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-base);
            color: var(--text-primary);
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
            min-height: 100vh;
            position: relative;
        }

        /* Ambient Animated Background Gradients */
        .ambient-blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.4;
            z-index: -1;
            animation: float 20s ease-in-out infinite;
            pointer-events: none;
        }

        .blob-1 {
            top: -10%; left: -10%;
            width: 50vw; height: 50vw;
            background: radial-gradient(circle, var(--accent-cool) 0%, transparent 70%);
        }

        .blob-2 {
            bottom: -20%; right: -10%;
            width: 60vw; height: 60vw;
            background: radial-gradient(circle, var(--accent-warm) 0%, transparent 70%);
            animation-direction: reverse;
            animation-delay: -5s;
        }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(30px, -50px) scale(1.1); }
            66% { transform: translate(-20px, 20px) scale(0.9); }
        }

        /* Typography */
        .mono { font-family: 'Space Mono', monospace; font-size: 0.8rem; letter-spacing: -0.02em; }

        /* =========================================
           NAVIGATION (GLASS ISLAND)
           ========================================= */
        header {
            position: fixed;
            top: 1.5rem;
            left: 50%;
            transform: translateX(-50%);
            width: calc(100% - 3rem);
            max-width: 1200px;
            z-index: 100;
            background: var(--glass-bg);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-full);
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 2rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        /* Sleek Branding */
        .brand {
            font-size: 1.4rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .brand-beams { color: var(--text-primary); }
        
        .brand-gn {
            background: linear-gradient(135deg, var(--accent-warm), var(--accent-bright));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .controls-group {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex: 1;
            justify-content: flex-end;
        }

        .search-wrapper {
            flex: 0 1 280px;
            position: relative;
        }

        .search-wrapper input {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-full);
            color: var(--text-primary);
            font-family: inherit;
            font-size: 0.9rem;
            padding: 0.6rem 1.2rem;
            transition: all 0.3s var(--ease-out);
        }

        .search-wrapper input:focus {
            outline: none;
            border-color: var(--accent-warm);
            background: rgba(255, 255, 255, 0.1);
        }

        .search-wrapper input::placeholder { color: var(--text-secondary); }

        .sort-controls {
            display: flex;
            gap: 0.25rem;
            background: rgba(0, 0, 0, 0.2);
            padding: 0.25rem;
            border-radius: var(--radius-full);
            border: 1px solid var(--glass-border);
        }

        .sort-btn {
            background: transparent;
            border: none;
            color: var(--text-secondary);
            padding: 0.4rem 1rem;
            border-radius: var(--radius-full);
            font-family: inherit;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s var(--ease-out);
        }

        .sort-btn.active, .sort-btn:hover {
            color: var(--bg-base);
            background: var(--text-primary);
        }

        /* =========================================
           MAIN CONTENT
           ========================================= */
        main {
            max-width: 1400px;
            margin: 0 auto;
            padding: 8rem 2rem 4rem;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .section-title {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
        }

        .section-count {
            background: rgba(255,255,255,0.1);
            padding: 0.2rem 0.6rem;
            border-radius: var(--radius-full);
            color: var(--text-secondary);
        }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 5rem;
        }

        #featuredZones {
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        }

        /* =========================================
           ZONE CARDS
           ========================================= */
        .zone-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            cursor: pointer;
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            transition: transform 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
            position: relative;
        }

        .zone-card:hover {
            transform: translateY(-6px);
            border-color: rgba(255, 255, 255, 0.3);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
        }

        .card-media {
            width: 100%;
            aspect-ratio: 16/10;
            overflow: hidden;
            position: relative;
        }

        .card-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s var(--ease-out);
            opacity: 0;
        }

        .card-media img.loaded { opacity: 1; }
        .zone-card:hover .card-media img { transform: scale(1.05); }

        .card-info {
            padding: 1.2rem;
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .card-title {
            font-size: 1.1rem;
            font-weight: 600;
        }

        .card-meta {
            color: var(--text-secondary);
            text-transform: uppercase;
        }

        /* Animation */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-enter {
            animation: fadeUp 0.6s var(--ease-out) forwards;
            opacity: 0;
        }

        /* =========================================
           VIEWER OVERLAY (IFRAME)
           ========================================= */
        .viewer-overlay {
            position: fixed;
            inset: 0;
            z-index: 500;
            background: rgba(11, 10, 16, 0.85);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            display: flex;
            flex-direction: column;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s var(--ease-out);
        }

        .viewer-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .viewer-header {
            padding: 1.2rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(0,0,0,0.4);
            border-bottom: 1px solid var(--glass-border);
        }

        .viewer-title-group h2 {
            font-size: 1.4rem;
            font-weight: 600;
        }

        .viewer-actions { display: flex; gap: 0.8rem; }

        .action-btn {
            background: rgba(255,255,255,0.1);
            color: var(--text-primary);
            border: 1px solid var(--glass-border);
            padding: 0.5rem 1.2rem;
            border-radius: var(--radius-full);
            font-family: inherit;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .action-btn:hover {
            background: var(--text-primary);
            color: var(--bg-base);
        }

        .btn-close {
            background: linear-gradient(135deg, var(--accent-warm), var(--accent-bright));
            border: none;
        }
        
        .btn-close:hover {
            opacity: 0.9;
            transform: scale(1.02);
            color: var(--text-primary);
        }

        .viewer-frame-container {
            flex: 1;
            width: 100%;
            height: 100%;
        }

        iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

        /* Responsive */
        @media (max-width: 768px) {
            header {
                flex-direction: column;
                border-radius: var(--radius-md);
                padding: 1rem;
                gap: 1rem;
            }
            .controls-group { width: 100%; justify-content: space-between; }
            .search-wrapper { flex: 1; }
            main { padding-top: 10rem; }
            .viewer-header { flex-direction: column; gap: 1rem; align-items: flex-start; }
            .viewer-actions { width: 100%; justify-content: stretch; }
            .action-btn { flex: 1; text-align: center; }
        }
    </style>
</head>
<body>

    <div class="ambient-blob blob-1"></div>
    <div class="ambient-blob blob-2"></div>

    <header id="mainNav">
        <a href="#" class="brand" onclick="window.scrollTo(0,0); return false;">
            <span class="brand-beams">Beam's</span>
            <span class="brand-gn">GN-MATH</span>
        </a>
        <div class="controls-group">
            <div class="search-wrapper">
                <input type="text" id="searchBar" placeholder="Search experiences..." autocomplete="off">
            </div>
            <div class="sort-controls">
                <button class="sort-btn active" data-sort="popular">Popular</button>
                <button class="sort-btn" data-sort="name">A-Z</button>
                <button class="sort-btn" data-sort="id">New</button>
            </div>
        </div>
    </header>

    <main>
        <section id="featuredSection">
            <div class="section-header">
                <h2 class="section-title">Featured</h2>
                <span class="section-count mono" id="featuredCount">0</span>
            </div>
            <div id="featuredZones" class="grid-container"></div>
        </section>

        <section id="catalogSection">
            <div class="section-header">
                <h2 class="section-title">All Experiences</h2>
                <span class="section-count mono" id="catalogCount">0</span>
            </div>
            <div id="allZones" class="grid-container"></div>
        </section>
    </main>

    <div id="zoneViewer" class="viewer-overlay">
        <div class="viewer-header">
            <div class="viewer-title-group">
                <h2 id="viewTitle">Project Name</h2>
            </div>
            <div class="viewer-actions">
                <button class="action-btn" id="btnFullscreen">Fullscreen</button>
                <button class="action-btn btn-close" id="btnCloseViewer">Close Context</button>
            </div>
        </div>
        <div class="viewer-frame-container" id="frameContainer"></div>
    </div>

    <script>
        const CONFIG = {
            endpoints: [
                "https://cdn.jsdelivr.net/gh/gn-math/assets@main/zones.json",
                "https://cdn.jsdelivr.net/gh/gn-math/assets@latest/zones.json",
                "https://cdn.jsdelivr.net/gh/gn-math/assets/zones.json"
            ],
            coverBase: "https://cdn.jsdelivr.net/gh/gn-math/covers@main",
            htmlBase: "https://cdn.jsdelivr.net/gh/gn-math/html@main",
            statsEndpoint: "https://data.jsdelivr.com/v1/stats/packages/gh/gn-math/html@main/files?period=year"
        };

        const state = {
            zones: [],
            popularity: {},
            currentSort: 'popular',
            searchQuery: ''
        };

        const DOM = {
            featured: document.getElementById('featuredZones'),
            catalog: document.getElementById('allZones'),
            search: document.getElementById('searchBar'),
            sortBtns: document.querySelectorAll('.sort-btn'),
            viewer: document.getElementById('zoneViewer'),
            frameContainer: document.getElementById('frameContainer')
        };

        async function initializeCatalog() {
            try {
                const endpoint = CONFIG.endpoints[Math.floor(Math.random() * CONFIG.endpoints.length)];
                const [zonesRes, statsRes] = await Promise.allSettled([
                    fetch(`${endpoint}?t=${Date.now()}`).then(r => r.json()),
                    fetch(CONFIG.statsEndpoint).then(r => r.json())
                ]);

                if (zonesRes.status === 'fulfilled') {
                    state.zones = zonesRes.value;
                    if(state.zones.length > 0) state.zones[0].featured = true;
                }

                if (statsRes.status === 'fulfilled') {
                    statsRes.value.forEach(file => {
                        const match = file.name.match(/\/(\d+)\.html$/);
                        if (match) state.popularity[parseInt(match[1])] = file.hits.total;
                    });
                }

                renderLogic();
            } catch (err) {
                DOM.catalog.innerHTML = `<p class="mono text-secondary">Unable to load catalog data.</p>`;
            }
        }

        function renderLogic() {
            let processed = [...state.zones];

            if (state.searchQuery) {
                const q = state.searchQuery.toLowerCase();
                processed = processed.filter(z => z.name.toLowerCase().includes(q));
                document.getElementById('featuredSection').style.display = 'none';
            } else {
                document.getElementById('featuredSection').style.display = 'block';
            }

            processed.sort((a, b) => {
                if (state.currentSort === 'name') return a.name.localeCompare(b.name);
                if (state.currentSort === 'id') return a.id - b.id;
                return (state.popularity[b.id] || 0) - (state.popularity[a.id] || 0);
            });

            processed.sort((a, b) => (a.id === -1 ? -1 : b.id === -1 ? 1 : 0));

            const featured = processed.filter(z => z.featured);
            
            renderGrid(featured, DOM.featured, 'featuredCount');
            renderGrid(processed, DOM.catalog, 'catalogCount');
            setupLazyLoading();
        }

        function renderGrid(data, container, countId) {
            container.innerHTML = '';
            document.getElementById(countId).innerText = data.length;

            data.forEach((item, i) => {
                const card = document.createElement('div');
                card.className = 'zone-card animate-enter';
                card.style.animationDelay = `${i * 0.04}s`;
                card.onclick = () => launchZone(item);

                const coverUrl = item.cover.replace("{COVER_URL}", CONFIG.coverBase).replace("{HTML_URL}", CONFIG.htmlBase);

                card.innerHTML = `
                    <div class="card-media">
                        <img data-src="${coverUrl}" alt="${item.name}" loading="lazy">
                    </div>
                    <div class="card-info">
                        <div class="card-title">${item.name}</div>
                        <div class="card-meta mono">${item.author || 'Unknown'}</div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function setupLazyLoading() {
            const observer = new IntersectionObserver((entries, obs) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const img = entry.target;
                        img.src = img.dataset.src;
                        img.onload = () => img.classList.add('loaded');
                        obs.unobserve(img);
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.card-media img').forEach(img => observer.observe(img));
        }

        async function launchZone(item) {
            if (item.url.startsWith("http")) {
                window.open(item.url, "_blank");
                return;
            }

            const url = item.url.replace("{COVER_URL}", CONFIG.coverBase).replace("{HTML_URL}", CONFIG.htmlBase);
            
            try {
                const res = await fetch(`${url}?t=${Date.now()}`);
                const html = await res.text();

                // Inject purely the game context, NO popups or extraneous wrappers.
                DOM.frameContainer.innerHTML = '<iframe id="activeFrame"></iframe>';
                const frame = document.getElementById('activeFrame');
                
                frame.contentDocument.open();
                frame.contentDocument.write(html);
                frame.contentDocument.close();

                document.getElementById('viewTitle').innerText = item.name;

                DOM.viewer.classList.add('active');
                document.body.style.overflow = 'hidden';

            } catch (err) {
                alert("Failed to load environment.");
            }
        }

        function closeViewer() {
            DOM.viewer.classList.remove('active');
            DOM.frameContainer.innerHTML = '';
            document.body.style.overflow = '';
        }

        // Event Listeners
        DOM.search.addEventListener('input', (e) => {
            state.searchQuery = e.target.value;
            renderLogic();
        });

        DOM.sortBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                DOM.sortBtns.forEach(b => b.classList.remove('active'));
                e.target.classList.add('active');
                state.currentSort = e.target.dataset.sort;
                renderLogic();
            });
        });

        document.getElementById('btnCloseViewer').addEventListener('click', closeViewer);

        document.getElementById('btnFullscreen').addEventListener('click', () => {
            const frame = document.getElementById('activeFrame');
            if(frame) {
                if (frame.requestFullscreen) frame.requestFullscreen();
                else if (frame.webkitRequestFullscreen) frame.webkitRequestFullscreen();
            }
        });

        // Network Layer overrides to prevent external blockers
        const filterList = ["deledao", "goguardian", "lightspeed", "linewize", "securly", ".edu/"];
        const isBlocked = (url) => {
            try { return filterList.some(s => new URL(url, location.origin).hostname.includes(s)); } 
            catch { return false; }
        };

        const origFetch = window.fetch;
        window.fetch = function(url, options) {
            if (isBlocked(url)) return Promise.reject(new Error("Intercepted"));
            return origFetch.apply(this, arguments);
        };

        const origOpen = XMLHttpRequest.prototype.open;
        XMLHttpRequest.prototype.open = function(method, url) {
            if (isBlocked(url)) return;
            return origOpen.apply(this, arguments);
        };

        initializeCatalog();
    </script>
</body>
</html>
